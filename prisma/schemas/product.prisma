// ============================================
// ENUMS
// ============================================

enum Gender {
  MEN
  WOMEN
  UNISEX
  KIDS
}


enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
  DISCONTINUED
}

enum SizeSystem {
  US
  EU
  UK
}

// ============================================
// MODELS
// ============================================

model Product {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(255)
  slug              String             @unique @db.VarChar(255)
  brand             String             @db.VarChar(255)
  description       String?            @db.Text
  shortDescription  String?            @db.VarChar(500)
  gender            Gender
  shoeType          String             @db.VarChar(100)
  category          String             @db.VarChar(255)
  releaseDate       DateTime?
  basePrice         Float
  featuredProduct   Boolean            @default(false)
  newArrival        Boolean            @default(false)
  status            ProductStatus      @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  variants          ProductVariant[]
  images            ProductImage[]
  shoeSpecification ShoeSpecification?
  sizeGuides        SizeGuide[]
  reviews           ProductReview[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  orderItems        OrderItem[]

  @@index([slug])
  @@index([category])
  @@index([status])
}

model ProductVariant {
  id              String      @id @default(uuid())
  productId       String
  sku             String      @unique @db.VarChar(100)
  size            String      @db.VarChar(50)
  material        String?     @db.VarChar(255)
  color           String      @db.VarChar(100)
  width           String?     @db.VarChar(50)
  price           Float
  comparePrice    Float?
  weight          Float?
  barcode         String?     @unique @db.VarChar(100)
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory       Inventory?
  images          ProductImage[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]

  @@index([productId])
  @@index([sku])
  @@index([color])
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  variantId   String?
  imageUrl    String   @db.Text
  altText     String?  @db.VarChar(255)
  position    Int      @default(0)
  isThumbnail Boolean  @default(false)
  createdAt   DateTime @default(now())

  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
}

model ProductTag {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  @@index([slug])
}

model ShoeSpecification {
  id               String   @id @default(uuid())
  productId        String   @unique
  material         String?  @db.VarChar(255)
  soleMaterial     String?  @db.VarChar(255)
  upperMaterial    String?  @db.VarChar(255)
  cushioningType   String?  @db.VarChar(100)
  heelHeight       Float?
  closureType      String?  @db.VarChar(100)
  waterproof       Boolean  @default(false)
  breathable       Boolean  @default(false)
  weight           Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model SizeGuide {
  id           String   @id @default(uuid())
  productId    String
  sizeSystem   SizeSystem
  sizeValue    String   @db.VarChar(50)
  footLength   Float?
  createdAt    DateTime @default(now())

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@unique([productId, sizeSystem, sizeValue])
}