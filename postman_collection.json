{
  "info": {
    "name": "Sprint Shoes Authentication API",
    "description": "Complete authentication testing for Sprint Shoes e-commerce platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "sprint-shoes-auth"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "user_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "phone_number",
      "value": "+1234567890",
      "type": "string"
    },
    {
      "key": "test_email",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "otp",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User Authentication",
      "item": [
        {
          "name": "Registration Flow",
          "item": [
            {
              "name": "1. Initiate Phone Registration",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.otp) {",
                      "        pm.collectionVariables.set('otp', response.otp);",
                      "        console.log('OTP:', response.otp);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/register/initiate-phone",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "register", "initiate-phone"]
                },
                "description": "Send OTP to phone number to start registration"
              },
              "response": []
            },
            {
              "name": "2. Verify Phone OTP",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.sessionId) {",
                      "        pm.collectionVariables.set('session_id', response.sessionId);",
                      "        console.log('Session ID:', response.sessionId);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"otp\": \"{{otp}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/register/verify-phone",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "register", "verify-phone"]
                },
                "description": "Verify OTP and get session ID"
              },
              "response": []
            },
            {
              "name": "3. Complete Registration",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    const response = pm.response.json();",
                      "    if (response.data) {",
                      "        pm.collectionVariables.set('user_access_token', response.data.accessToken);",
                      "        pm.collectionVariables.set('user_refresh_token', response.data.refreshToken);",
                      "        console.log('Access Token:', response.data.accessToken);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"sessionId\": \"{{session_id}}\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"SecurePass123!\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/register/complete",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "register", "complete"]
                },
                "description": "Complete registration with user details"
              },
              "response": []
            }
          ]
        },
        {
          "name": "Login Flow",
          "item": [
            {
              "name": "Login with Email & Password",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.data) {",
                      "        pm.collectionVariables.set('user_access_token', response.data.accessToken);",
                      "        pm.collectionVariables.set('user_refresh_token', response.data.refreshToken);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"SecurePass123!\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "login"]
                },
                "description": "Login with email and password"
              },
              "response": []
            },
            {
              "name": "Request Login OTP",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.otp) {",
                      "        pm.collectionVariables.set('otp', response.otp);",
                      "        console.log('Login OTP:', response.otp);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/login/request-otp",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "login", "request-otp"]
                },
                "description": "Request OTP for phone-based login"
              },
              "response": []
            },
            {
              "name": "Login with Phone & OTP",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.data) {",
                      "        pm.collectionVariables.set('user_access_token', response.data.accessToken);",
                      "        pm.collectionVariables.set('user_refresh_token', response.data.refreshToken);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"otp\": \"{{otp}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/login/phone",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "login", "phone"]
                },
                "description": "Login with phone number and OTP"
              },
              "response": []
            }
          ]
        },
        {
          "name": "Token Management",
          "item": [
            {
              "name": "Get Current User",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{user_access_token}}",
                    "type": "text"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/user/auth/me",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "me"]
                },
                "description": "Get authenticated user details (requires valid access token)"
              },
              "response": []
            },
            {
              "name": "Refresh Access Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const response = pm.response.json();",
                      "    if (response.data && response.data.accessToken) {",
                      "        pm.collectionVariables.set('user_access_token', response.data.accessToken);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{user_refresh_token}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/refresh",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "refresh"]
                },
                "description": "Get new access token using refresh token"
              },
              "response": []
            },
            {
              "name": "Logout",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    pm.collectionVariables.set('user_access_token', '');",
                      "    pm.collectionVariables.set('user_refresh_token', '');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{user_refresh_token}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/logout",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "logout"]
                },
                "description": "Logout and invalidate refresh token"
              },
              "response": []
            }
          ]
        },
        {
          "name": "Password Reset",
          "item": [
            {
              "name": "Forgot Password",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{test_email}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/forgot-password",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "forgot-password"]
                },
                "description": "Request password reset email"
              },
              "response": []
            },
            {
              "name": "Reset Password",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"token\": \"RESET_TOKEN_FROM_EMAIL\",\n  \"newPassword\": \"NewSecurePass123!\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/user/auth/reset-password",
                  "host": ["{{base_url}}"],
                  "path": ["api", "user", "auth", "reset-password"]
                },
                "description": "Reset password with token from email"
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Admin Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data) {",
                  "        pm.collectionVariables.set('admin_access_token', response.data.accessToken);",
                  "        pm.collectionVariables.set('admin_refresh_token', response.data.refreshToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sprintshoes.com\",\n  \"password\": \"AdminPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "login"]
            },
            "description": "Admin login with email and password"
          },
          "response": []
        },
        {
          "name": "Get Current Admin",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "me"]
            },
            "description": "Get authenticated admin details"
          },
          "response": []
        },
        {
          "name": "Refresh Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.accessToken) {",
                  "        pm.collectionVariables.set('admin_access_token', response.data.accessToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "refresh"]
            },
            "description": "Get new admin access token"
          },
          "response": []
        },
        {
          "name": "Get Activity Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/auth/activity-logs?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "activity-logs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get admin activity logs with pagination"
          },
          "response": []
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/auth/sessions/SESSION_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "sessions", "SESSION_ID_HERE"]
            },
            "description": "Revoke a specific admin session"
          },
          "response": []
        },
        {
          "name": "Admin Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('admin_access_token', '');",
                  "    pm.collectionVariables.set('admin_refresh_token', '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "logout"]
            },
            "description": "Admin logout and invalidate refresh token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        },
        "description": "Check if server is running"
      },
      "response": []
    }
  ]
}
