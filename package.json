{
  "name": "shoe-store-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "build-schema": "node scripts/build-schema.js",
    "prisma:generate": "npm run build-schema && prisma generate",
    "prisma:migrate": "npm run build-schema && prisma migrate dev",
    "start": "NODE_ENV=production node dist/app.js",
    "build": "npm run build-schema && npm run lint && tsc -p .",
    "dev": "npm run build-schema && tsx watch src/app.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "seed": "npm run build-schema && tsx prisma/seed.ts",
    "db:seed": "npm run build-schema && prisma db seed",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.5.4",
    "cors": "2.8.6",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "1.10.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.21",
    "@types/helmet": "4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/twilio": "^3.19.2",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
