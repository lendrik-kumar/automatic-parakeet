# ─── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=DEVELOPMENT
PORT=3000

# ─── Database Configuration ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sprint_shoes

# Docker Compose database variables (used in Docker-compose.yml)
DB_USER=user
DB_PASSWORD=password
DB_NAME=sprint_shoes
DB_PORT=5432

# ─── Authentication / JWT Configuration ──────────────────────────────────────
# [REQUIRED - secret key] Used by better-auth and JWT signing. Generate a strong random string.
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production
# [REQUIRED - secret key] Fallback secret for JWT if BETTER_AUTH_SECRET is not set.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Base URL of the API server (used by better-auth)
BASE_URL=http://localhost:3000

# ─── Redis Configuration ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Email Configuration (Resend) ──────────────────────────────────────────
# [REQUIRED - API key] Obtain from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@sprintshoes.com

# ─── SMS Configuration (Fast2SMS) ──────────────────────────────────────
# [REQUIRED - API key] Obtain from https://www.fast2sms.com → Dev API section
FAST2SMS_API_KEY=your-fast2sms-api-key

# ─── Frontend URL ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Razorpay Payment Gateway Configuration ─────────────────────────────────
# [REQUIRED - API keys] Obtain from https://dashboard.razorpay.com/#/app/keys
# Test keys start with rzp_test_, live keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# [OPTIONAL] Webhook secret for signature verification (recommended for production)
# Generate from Razorpay Dashboard → Webhooks → Add Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# [OPTIONAL] Payment capture mode (automatic | manual)
# automatic: Payment is captured immediately after authorization
# manual: You must manually capture payment within 5 days
RAZORPAY_CAPTURE_MODE=automatic

# [OPTIONAL] Default currency (USD | INR)
# INR is recommended for Razorpay as it's primarily for Indian market
RAZORPAY_DEFAULT_CURRENCY=USD

# [OPTIONAL] Payment timeout in seconds (default: 900 = 15 minutes)
RAZORPAY_PAYMENT_TIMEOUT=900

# ─── Docker Compose ─────────────────────────────────────────────────────────
# Host port for the app container
APP_PORT=3000
# Set to "true" to run the seed script on container startup
ENABLE_SEED=false

